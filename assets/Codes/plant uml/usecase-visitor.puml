@startuml
title حالات الاستخدام - الزائر
left to right direction
skinparam packageStyle rectangle

actor "زائر" as Visitor

rectangle "منصة زاد للعقارات" {
  usecase "عرض الصفحة الرئيسية" as UC_Home
  usecase "تصفح العقارات" as UC_Estates
  usecase "البحث والفلترة" as UC_Search
  usecase "البحث على الخريطة" as UC_Map
  usecase "عرض تفاصيل عقار" as UC_EstateDetails
  usecase "تصفح المدن والمناطق" as UC_Locations
  usecase "تصفح الوسطاء" as UC_Agents
  usecase "تصفح الشركات" as UC_Companies
  usecase "قراءة التقييمات ودرجة الثقة" as UC_Reviews
  usecase "مشاركة عقار أو وسيط" as UC_Share
  usecase "تسجيل حساب / تسجيل الدخول" as UC_Auth
}

Visitor --> UC_Home
Visitor --> UC_Estates
Visitor --> UC_Search
Visitor --> UC_Map
Visitor --> UC_EstateDetails
Visitor --> UC_Locations
Visitor --> UC_Agents
Visitor --> UC_Companies
Visitor --> UC_Reviews
Visitor --> UC_Share
Visitor --> UC_Auth
@enduml
